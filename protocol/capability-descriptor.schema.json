{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-descriptor.schema.json",
  "title": "Seoul capability descriptor (canonical wire, protocol version 1)",
  "description": "One typed operation Seoul can plan with, regardless of who supplies it. Mirrors native/seoul/browser/tools/tool_types.h ToolDescriptor. \"Tool\" and \"capability\" are the same concept; the id is the stable CapabilityId. Input/output schemas use the same bounded JSON-Schema subset native/seoul/browser/tools/tool_schema_from_json.cc accepts.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "provider"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*){1,3}$",
      "description": "Namespaced dotted identifier, two to four segments."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "The descriptor's own contract version; bump on breaking schema changes."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Planner-facing behavior contract."
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "\"seoul\" for builtins; connector id otherwise. Synthetic Design Lab fixtures use \"fixture\"."
    },
    "input_schema": {
      "$ref": "#/$defs/tool_schema"
    },
    "output_schema": {
      "$ref": "#/$defs/tool_schema"
    },
    "capability_tags": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "maxLength": 64
      }
    },
    "requires_network": {
      "type": "boolean"
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "none",
        "organization",
        "page_content",
        "personal",
        "credential_adjacent"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "read_only",
        "reversible_mutation",
        "irreversible_mutation",
        "external_side_effect"
      ]
    },
    "approval": {
      "type": "string",
      "enum": [
        "never_required",
        "first_use_per_scope",
        "always_required"
      ]
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "cancellable": {
      "type": "boolean"
    },
    "supports_streaming": {
      "type": "boolean"
    },
    "idempotency": {
      "type": "string",
      "enum": [
        "idempotent",
        "not_idempotent"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "real_time",
        "near_real_time",
        "cached",
        "static"
      ]
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "backoff_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "observation_contract": {
      "type": "string",
      "maxLength": 1024,
      "description": "What observable state change proves the tool ran. Empty for pure reads; for fixtures this states that no real observation exists."
    },
    "verifier_id": {
      "type": "string",
      "maxLength": 128
    },
    "preferred_component": {
      "description": "Optional SAUI component wire name best suited to render results.",
      "$ref": "adaptive-surface.schema.json#/$defs/component_type"
    }
  },
  "$defs": {
    "tool_schema": {
      "type": "object",
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "object"
        },
        "properties": {
          "type": "object",
          "maxProperties": 64,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/schema_field"
          }
        },
        "required": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "schema_field": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "string",
            "integer",
            "number",
            "boolean",
            "array",
            "object"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 1024
        },
        "enum": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "string",
            "maxLength": 200
          }
        },
        "format": {
          "type": "string",
          "enum": [
            "uri"
          ]
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16384
        },
        "items": {
          "$ref": "#/$defs/schema_field"
        },
        "properties": {
          "type": "object",
          "maxProperties": 64,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]{0,63}$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/schema_field"
          }
        },
        "required": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
