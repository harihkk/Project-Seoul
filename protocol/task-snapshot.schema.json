{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-snapshot.schema.json",
  "title": "Seoul task snapshot (canonical wire, protocol version 1)",
  "description": "A read snapshot of one task for rendering: state, plan origin, bounded action receipts, budget usage, approval state, and window association. Mirrors native/seoul/browser/product/task_service.h TaskSnapshot and native/seoul/browser/tasks/task_types.h. This is the typed document the Canvas renders task progress from; it replaces free-form status strings.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "goal",
    "state"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "goal": {
      "type": "string",
      "maxLength": 4096
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "planning",
        "awaiting_approval",
        "executing",
        "paused",
        "monitoring",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "failure": {
      "type": "string",
      "enum": [
        "none",
        "step_failed",
        "budget_exhausted",
        "assumption_invalid",
        "user_stopped",
        "provider_unavailable"
      ]
    },
    "plan_origin": {
      "type": "string",
      "enum": [
        "deterministic",
        "local",
        "cloud"
      ]
    },
    "receipts": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/action_receipt"
      }
    },
    "usage": {
      "$ref": "#/$defs/budget_usage"
    },
    "pending_approval_step": {
      "type": "string",
      "maxLength": 64,
      "description": "Non-empty while awaiting approval or typed user input."
    },
    "pending_approval_prompt": {
      "type": "string",
      "maxLength": 1024
    },
    "pending_user_input": {
      "type": "boolean",
      "description": "True when the pending interaction requires typed user input rather than approval."
    },
    "has_semantic_result": {
      "type": "boolean"
    },
    "window": {
      "type": "string",
      "pattern": "^w-[1-9][0-9]*$",
      "description": "LiveWindowKey wire form (\"w-<session_id>\"). Absent when the task is not window-bound."
    },
    "replans_used": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "step_status": {
      "type": "string",
      "enum": [
        "pending",
        "awaiting_approval",
        "awaiting_input",
        "running",
        "succeeded",
        "failed",
        "outcome_unknown",
        "skipped",
        "cancelled"
      ]
    },
    "execution_route": {
      "type": "string",
      "enum": [
        "deterministic",
        "local",
        "cloud"
      ]
    },
    "verification_record": {
      "type": "object",
      "required": [
        "verified",
        "method"
      ],
      "additionalProperties": false,
      "properties": {
        "verified": {
          "type": "boolean"
        },
        "method": {
          "type": "string",
          "maxLength": 128,
          "description": "\"postcondition\", \"observation\", \"verifier:<id>\", or \"fixture_contract\" for synthetic Design Lab fixtures. Never claim observation for a fixture."
        },
        "detail": {
          "type": "string",
          "maxLength": 1024
        }
      }
    },
    "action_receipt": {
      "type": "object",
      "required": [
        "step_id",
        "tool",
        "status",
        "verification",
        "route"
      ],
      "additionalProperties": false,
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "tool": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*){1,3}$",
          "description": "ToolId: namespaced dotted identifier, two to four segments."
        },
        "status": {
          "$ref": "#/$defs/step_status"
        },
        "started_at_ms": {
          "type": "number"
        },
        "finished_at_ms": {
          "type": "number"
        },
        "observed_summary": {
          "type": "string",
          "maxLength": 1024,
          "description": "What actually happened, from observation. For fixture execution this must describe the fixture, never a real browser state."
        },
        "verification": {
          "$ref": "#/$defs/verification_record"
        },
        "route": {
          "$ref": "#/$defs/execution_route"
        },
        "cost_microdollars": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "navigations": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "budget_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps_executed": {
          "type": "integer",
          "minimum": 0
        },
        "model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "navigations": {
          "type": "integer",
          "minimum": 0
        },
        "cloud_cost_microdollars": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "replans_used": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
