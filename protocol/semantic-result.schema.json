{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "semantic-result.schema.json",
  "title": "Seoul semantic result (canonical wire, protocol version 1)",
  "description": "The versioned, domain-neutral result model every Seoul capability outcome uses. Mirrors native/seoul/browser/semantic/semantic_types.h exactly: a shape plus fields whose meaning is carried by semantic roles and metadata. Field-level bounds beyond structure (row limits, finite numbers, role coherence per shape, undeclared-key rejection) are enforced by the semantic validators on each side, not by this schema.",
  "type": "object",
  "required": ["schema", "data", "provenance"],
  "additionalProperties": false,
  "properties": {
    "schema": { "$ref": "#/$defs/semantic_schema" },
    "data": {
      "description": "Shape-specific layout. scalar: one primitive. record/document/artifact/diff: dict keyed by field id. List shapes: list of dicts keyed by field id. graph: {nodes: [...], edges: [...]}. composite: dict keyed by part name."
    },
    "provenance": { "$ref": "#/$defs/semantic_provenance" },
    "state": {
      "type": "string",
      "enum": ["complete", "partial", "streaming", "failed"],
      "description": "ResultState. Defaults to complete when absent."
    },
    "continuation_token": {
      "type": "string",
      "maxLength": 4096,
      "description": "Pagination continuation; empty or absent when none."
    },
    "unavailable_field_ids": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/field_id" },
      "description": "Fields the source could not supply. They must be absent from the data: gaps are reported, never fabricated."
    },
    "errors": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/semantic_error" }
    },
    "conflicts": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/source_conflict" }
    }
  },
  "$defs": {
    "field_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "semantic_shape": {
      "type": "string",
      "enum": [
        "scalar",
        "record",
        "entity_collection",
        "table",
        "cube",
        "series",
        "time_series",
        "interval_series",
        "event_stream",
        "status_stream",
        "hierarchy",
        "graph",
        "geo_features",
        "route",
        "document",
        "document_sections",
        "citations",
        "media",
        "artifact",
        "form_schema",
        "action_set",
        "diff",
        "code_structure",
        "composite"
      ]
    },
    "semantic_role": {
      "type": "string",
      "enum": [
        "none",
        "identifier",
        "name",
        "description",
        "measure",
        "dimension",
        "timestamp",
        "interval_start",
        "interval_end",
        "duration",
        "latitude",
        "longitude",
        "url",
        "media_url",
        "category",
        "status",
        "severity",
        "money",
        "percentage",
        "count",
        "open",
        "high",
        "low",
        "close",
        "parent_reference",
        "source_node",
        "target_node",
        "body",
        "citation_ref",
        "mime_type"
      ]
    },
    "field_primitive": {
      "type": "string",
      "enum": ["string", "integer", "number", "boolean", "timestamp"]
    },
    "value_class": {
      "type": "string",
      "enum": ["categorical", "ordinal", "continuous", "free_text"]
    },
    "field_sensitivity": {
      "type": "string",
      "enum": ["public", "personal", "sensitive"]
    },
    "field_spec": {
      "type": "object",
      "required": ["id", "label", "primitive"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/field_id" },
        "label": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "maxLength": 1024 },
        "primitive": { "$ref": "#/$defs/field_primitive" },
        "nullable": { "type": "boolean" },
        "role": { "$ref": "#/$defs/semantic_role" },
        "unit": { "type": "string", "maxLength": 64 },
        "currency_code": { "type": "string", "maxLength": 8 },
        "locale": { "type": "string", "maxLength": 32 },
        "timezone": { "type": "string", "maxLength": 64 },
        "format": { "type": "string", "maxLength": 64 },
        "value_class": { "$ref": "#/$defs/value_class" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "precision": { "type": "integer", "minimum": -1, "maximum": 12 },
        "sensitivity": { "$ref": "#/$defs/field_sensitivity" },
        "sortable": { "type": "boolean" },
        "filterable": { "type": "boolean" },
        "aggregatable": { "type": "boolean" }
      }
    },
    "semantic_schema": {
      "type": "object",
      "required": ["schema_version", "shape"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": 1 },
        "shape": { "$ref": "#/$defs/semantic_shape" },
        "fields": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/field_spec" }
        },
        "edge_fields": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/field_spec" },
          "description": "Graph edges only."
        },
        "parts": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/semantic_schema" },
          "description": "Composite children; recursion bounded to depth 4 by the validators."
        },
        "part_names": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/field_id" }
        }
      }
    },
    "citation": {
      "type": "object",
      "required": ["url"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "maxLength": 4096 },
        "title": { "type": "string", "maxLength": 512 }
      }
    },
    "freshness_state": {
      "type": "string",
      "enum": ["real_time", "delayed", "cached", "stale"]
    },
    "semantic_provenance": {
      "type": "object",
      "required": ["source_name", "retrieved_at_ms"],
      "additionalProperties": false,
      "properties": {
        "source_name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "source_url": { "type": "string", "maxLength": 4096 },
        "retrieved_at_ms": { "type": "number" },
        "effective_at_ms": { "type": "number" },
        "timezone": { "type": "string", "maxLength": 64 },
        "units": { "type": "string", "maxLength": 64 },
        "freshness": { "$ref": "#/$defs/freshness_state" },
        "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
        "provider": { "type": "string", "maxLength": 200 },
        "transformations": {
          "type": "array",
          "maxItems": 32,
          "items": { "type": "string", "maxLength": 200 }
        },
        "citations": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/citation" }
        }
      }
    },
    "semantic_error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 128 },
        "message": { "type": "string", "maxLength": 1024 }
      }
    },
    "source_conflict": {
      "type": "object",
      "required": ["field_id", "source_a", "source_b"],
      "additionalProperties": false,
      "properties": {
        "field_id": { "$ref": "#/$defs/field_id" },
        "source_a": { "type": "string", "minLength": 1, "maxLength": 200 },
        "source_b": { "type": "string", "minLength": 1, "maxLength": 200 },
        "note": { "type": "string", "maxLength": 1024 }
      }
    }
  }
}
