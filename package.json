{
  "name": "project-seoul-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Project Seoul development harness - a Manifest V3 browser-control runtime slice.",
  "scripts": {
    "clean": "node scripts/build-extension.mjs --clean-only",
    "build": "node scripts/build-extension.mjs",
    "validate": "node scripts/validate-extension.mjs",
    "test": "node --test apps/browser-harness/tests/protocol.test.mjs apps/browser-harness/tests/validation.test.mjs apps/browser-harness/tests/control-session-machine.test.mjs apps/browser-harness/tests/control-session-store.test.mjs apps/browser-harness/tests/session.test.mjs apps/browser-harness/tests/sidepanel-ui.test.mjs",
    "check": "tsc --noEmit -p tsconfig.json && npm run build && npm run validate && npm test",
    "itest": "npm run build && node --test --test-concurrency=1 apps/browser-harness/itest/action-panel.itest.mjs apps/browser-harness/itest/tab-isolation.itest.mjs apps/browser-harness/itest/panel-lifecycle.itest.mjs apps/browser-harness/itest/navigation-invalidation.itest.mjs apps/browser-harness/itest/security.itest.mjs",
    "itest:headful": "npm run build && SEOUL_HEADFUL=1 node --test --test-concurrency=1 apps/browser-harness/itest/action-panel.itest.mjs apps/browser-harness/itest/tab-isolation.itest.mjs apps/browser-harness/itest/panel-lifecycle.itest.mjs apps/browser-harness/itest/navigation-invalidation.itest.mjs apps/browser-harness/itest/security.itest.mjs",
    "itest:resilience": "npm run build && node --test --test-concurrency=1 apps/browser-harness/itest/worker-recovery-storage.resilience.mjs apps/browser-harness/itest/forced-worker-loss.resilience.mjs"
  },
  "devDependencies": {
    "@types/chrome": "0.2.0",
    "puppeteer": "25.2.1",
    "typescript": "6.0.3"
  }
}
