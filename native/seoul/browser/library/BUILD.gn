}

test("seoul_library_unittests") {
  testonly = true
  sources = [ "library_service_unittest.cc" ]
  deps = [
    ":library_core",
    "//base",
    "//base/test:run_all_unittests",
    "//base/test:test_support",
    "//testing/gtest",
  ]
}
