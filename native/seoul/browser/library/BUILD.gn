# Project Seoul Library, Boards, and Live Collections.

import("//testing/test.gni")

source_set("library_core") {
  sources = [
    "library_service.cc",
    "library_service.h",
    "library_types.cc",
    "library_types.h",
  ]
  deps = [
    "//base",
    "//seoul/browser/tools:tools_core",
